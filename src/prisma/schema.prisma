generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Drug {
    id               Int      @id @default(autoincrement())
    genericName      String   @unique @map("generic_name")
    brandName        String?  @map("brand_name")
    substanceName    String?  @map("substance_name")
    pharmClassEpc    String?  @map("pharm_class_epc")
    rxcui            String[]
    route            String?
    manufacturerName String?  @map("manufacturer_name")

    chunks Chunk[]

    @@map("drugs")
}

model Chunk {
    id          Int                          @id @default(autoincrement())
    content     String
    embedding   Unsupported("vector(3072)")?
    section     String
    sourceField String?                      @map("source_field")

    drugGenericName String @map("drug_generic_name")
    drug            Drug   @relation(fields: [drugGenericName], references: [genericName])

    @@index([drugGenericName])
    @@index([section])
    @@map("chunks")
}
